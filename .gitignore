# Keep this repository limited to the GitHub Pages site.
# Ignore every top-level item unless it is explicitly required below.
/*

!/.github/
/.github/*
!/.github/workflows/
/.github/workflows/*
!/.github/workflows/deploy-pages.yml
!/.gitignore
!/README.md
!/app/
/app/*
!/app/globals.css
!/app/layout.tsx
!/app/page.tsx
!/app/components/
/app/components/*
!/app/components/JourneyPlayground.module.css
!/app/components/JourneyPlayground.tsx
!/app/components/PredictionCheck.module.css
!/app/components/PredictionCheck.tsx
!/app/components/RequestThread.module.css
!/app/components/RequestThread.tsx
!/public/
/public/*
!/public/favicon.svg
!/public/og.png
!/tests/
/tests/*
!/tests/static-export.test.mjs
!/eslint.config.mjs
!/next.config.ts
!/package-lock.json
!/package.json
!/postcss.config.mjs
!/tsconfig.json

# Never publish local, generated, secret, or editor files inside allowed folders.
**/.DS_Store
**/node_modules/
**/.next/
**/out/
**/coverage/
**/*.log
**/*.pem
**/.env*
next-env.d.ts
